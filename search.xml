        <content type="html"><![CDATA[<link rel="stylesheet" class="aplayer-secondary-style-marker" href="\assets\css\APlayer.min.css"><script src="\assets\js\APlayer.min.js" class="aplayer-secondary-script-marker"></script><hr><h2 id="abbrlink-‘0’"><a href="#abbrlink-‘0’" class="headerlink" title="abbrlink: ‘0’"></a>abbrlink: ‘0’</h2><pre class="line-numbers language-js" data-language="js"><code class="language-js">#初始化仓库git init#提交文件到暂存区git add <span class="token operator">&lt;</span>file<span class="token operator">&gt;</span>#放弃提交文件并撤销修改git restore <span class="token operator">&lt;</span>file<span class="token operator">&gt;</span>#暂存区文件上传到仓库git commit <span class="token operator">-</span>m <span class="token string">"&lt;说明&gt;"</span>#查看仓库状态git status#查看版本日志git log#查看操作日志git reflog#回退版本git reset <span class="token operator">--</span>hard <span class="token constant">HEAD</span><span class="token operator">^</span> #回退上一个版本git reset <span class="token operator">--</span>hard <span class="token operator">&lt;</span>commit<span class="token operator">&gt;</span> #回退指定的版本#查看分支git branch#创建分支git branch <span class="token operator">&lt;</span>分支<span class="token operator">&gt;</span>#删除分支git branch <span class="token operator">-</span>d <span class="token operator">&lt;</span>分支<span class="token operator">&gt;</span>#切换分支git <span class="token keyword">switch</span> <span class="token operator">&lt;</span>分支<span class="token operator">&gt;</span>git checkout <span class="token operator">&lt;</span>分支<span class="token operator">&gt;</span>#合并分支git merge <span class="token operator">&lt;</span>分支<span class="token operator">&gt;</span>#添加远程仓库git remote add <span class="token operator">&lt;</span>origin<span class="token operator">&gt;</span> <span class="token operator">&lt;</span>仓库地址<span class="token operator">&gt;</span>#修改远程仓库git remote set<span class="token operator">-</span>url origin url#查看远程仓库列表git remote <span class="token operator">-</span>v#克隆远程仓库git clone <span class="token operator">&lt;</span>仓库地址<span class="token operator">&gt;</span>#上传文件到远程仓库git push <span class="token operator">-</span>u <span class="token operator">&lt;</span>origin<span class="token operator">&gt;</span> <span class="token operator">&lt;</span>master<span class="token operator">&gt;</span> <span class="token operator">-</span>f 强制上传#初始化仓库git init#连接远程仓库git remote add origin <span class="token punctuation">[</span>url<span class="token punctuation">]</span>#克隆仓库git clone <span class="token punctuation">[</span>url<span class="token punctuation">]</span>#配置用户名git config <span class="token operator">--</span>global user<span class="token punctuation">.</span>name <span class="token string">"[name]"</span>#配置邮箱地址git config <span class="token operator">--</span>global user<span class="token punctuation">.</span>email <span class="token string">"[email address]"</span>#创建新分支git branch <span class="token punctuation">[</span>branch_name<span class="token punctuation">]</span>#切换分支并更新工作目录git <span class="token keyword">switch</span> <span class="token operator">-</span>c <span class="token punctuation">[</span>branch_name<span class="token punctuation">]</span>#将指定分支合并到当前分支git merge <span class="token punctuation">[</span>branch<span class="token punctuation">]</span>#删除指定分支git branch <span class="token operator">-</span>d <span class="token punctuation">[</span>branch_name<span class="token punctuation">]</span>#查看当前分支版本历史git log#查看文件的版本历史git log <span class="token operator">--</span>follow <span class="token punctuation">[</span>file<span class="token punctuation">]</span>#查看分支的内容差异git diff <span class="token punctuation">[</span>first_branch<span class="token punctuation">]</span><span class="token operator">...</span><span class="token punctuation">[</span>second_branch<span class="token punctuation">]</span>#输出指定commit的元数据和内容变化git show <span class="token punctuation">[</span>commit<span class="token punctuation">]</span>#添加文件到暂存区git add <span class="token punctuation">[</span>file<span class="token punctuation">]</span>#提交暂存区文件到仓库git commit <span class="token operator">-</span>m <span class="token string">"[descriptive message]"</span><span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre>]]></content>
      
      
